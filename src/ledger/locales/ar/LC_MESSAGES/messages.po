msgstr "يحمل هذا السجل تحذيرات المحتوى التالية. راجِعها قبل المتابعة."

msgid "This record has access restrictions."
msgstr "لهذا السجل قيود وصول."

msgid "Those contact details are too long."
msgstr "بيانات الاتصال هذه طويلة جدًا."

msgid "Tick anything a reader should be warned about before this is shown."
msgstr "أشِّر على أي شيء ينبغي تحذير القارئ منه قبل عرض هذا."

msgid "Title"
msgstr "العنوان"

msgid "To"
msgstr "إلى"

msgid "To withdraw it, go to"
msgstr "لسحبه، انتقل إلى"

msgid "Transcript"
msgstr "نص مكتوب"

msgid "Type"
msgstr "النوع"

msgid "Types"
msgstr "الأنواع"

msgid "Version history"
msgstr "سجل الإصدارات"

msgid "View the audit log"
