#, python-brace-format
msgid ""
" Published as {visibility}, this record would be visible to {audience} — "
"it would not appear in public browse or search."
msgstr ""
" إذا نُشر بصفة {visibility}، فسيكون هذا السجل مرئيًا لـ {audience} — ولن "
"يظهر في التصفح أو البحث العام."

msgid "(add a content warning) — each records who acted and why."
msgstr "(إضافة تحذير محتوى) — يسجّل كلٌّ منها من قام بالإجراء ولماذا."

msgid "(change access),"
msgstr "(تغيير الوصول)،"

msgid ""
"A moderation decision needs a non-empty reason. Go back and supply a "
"rationale, then try again."
msgstr "يتطلب قرار الإشراف سببًا غير فارغ. ارجع وقدّم مبررًا، ثم حاول مرة أخرى."

msgid ""
"A steward reviews every submission before anything becomes visible — "
"nothing is published automatically."
msgstr "يراجع المشرف كل مساهمة قبل أن يصبح أي شيء مرئيًا — لا يُنشر شيء تلقائيًا."

msgid "A stranger sees nothing."
msgstr "لا يرى الغريب شيئًا."

msgid "A title is required."
msgstr "العنوان مطلوب."

msgid "About"
msgstr "حول"

msgid "Abuse — describes ongoing harm or mistreatment"
msgstr "إساءة — يصف أذًى أو سوء معاملة مستمرًّا"

msgid "Action a request with the audited CLI:"
msgstr "نفِّذ طلبًا عبر واجهة الأوامر المُدقَّقة:"

msgid "Action not recorded"
msgstr "لم يُسجَّل الإجراء"

msgid "Add content warning"
msgstr "إضافة تحذير محتوى"

msgid "Agent"
msgstr "الفاعل"

msgid ""
"All records you may view, with their titles, summaries, and whether each "
"carries a content warning."
msgstr ""
"جميع السجلات التي يمكنك عرضها، مع عناوينها وملخّصاتها وما إذا كان كلٌّ "
"منها يحمل تحذير محتوى."

msgid "An account is required."
msgstr "الحساب مطلوب."

msgid ""
"An at-a-glance summary of the public records in this archive — the "
"topics, kinds, and languages they cover. Every number counts only what is"
" publicly visible."
msgstr ""
"ملخّص سريع للسجلات العامة في هذا الأرشيف — الموضوعات والأنواع واللغات "
"التي تغطّيها. كل رقم يحصي ما هو مرئي علنًا فقط."

msgid "Apply dates"
msgstr "تطبيق التواريخ"

msgid "Are you named in this record and object to it? Tell a steward"
msgstr "هل أنت مذكور في هذا السجل وتعترض عليه؟ أخبر مشرفًا"

msgid "Are you the contributor? Manage or withdraw your consent"
msgstr "هل أنت المساهم؟ أدِر موافقتك أو اسحبها"

msgid "Attach a file (optional)"
msgstr "إرفاق ملف (اختياري)"

msgid "Audit log"
msgstr "سجل التدقيق"

msgid "Available at"
msgstr "متاح على"

msgid "Back to records"
msgstr "العودة إلى السجلات"

msgid "Back to the archive"
msgstr "العودة إلى الأرشيف"

msgid "Back to the record"
msgstr "العودة إلى السجل"

msgid "Back to the steward console"
msgstr "العودة إلى لوحة المشرف"

msgid "Before you act"
msgstr "قبل أن تتصرّف"

msgid "Browse"
msgstr "تصفّح"

msgid "Catalogue metadata"
msgstr "بيانات الفهرسة الوصفية"

msgid "Check a request"
msgstr "التحقق من طلب"

msgid "Check status"
msgstr "التحقق من الحالة"

msgid "Cite this record"
msgstr "استشهد بهذا السجل"

msgid "Clear filters"
msgstr "مسح المرشِّحات"

msgid "Collection overview"
msgstr "نظرة عامة على المجموعة"

msgid "Comma-separated topics, e.g. mutual aid, housing."
msgstr "موضوعات مفصولة بفواصل، مثل التعاضد، الإسكان."

msgid "Community only — vetted members"
msgstr "المجتمع فقط — أعضاء موثوقون"

msgid "Community only — vetted members of this community"
msgstr "المجتمع فقط — أعضاء موثوقون في هذا المجتمع"

#, python-brace-format
msgid "Comparing the current record with an earlier saved version. Record {id}."
msgstr "مقارنة السجل الحالي بنسخة سابقة محفوظة. السجل {id}."

msgid "Contact (optional, sealed)"
msgstr "جهة الاتصال (اختياري، مختوم)"

