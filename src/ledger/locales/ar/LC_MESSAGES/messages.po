msgid "That file is too large. The limit is {max} MB."
msgstr "هذا الملف كبير جدًا. الحد هو {max} ميغابايت."

#, python-brace-format
msgid "That file type isn't accepted. Allowed types are: {types}."
msgstr "نوع الملف هذا غير مقبول. الأنواع المسموح بها: {types}."

msgid "That submission is too long."
msgstr "هذه المساهمة طويلة جدًا."

